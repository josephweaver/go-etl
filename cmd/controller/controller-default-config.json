{
  "variables": [
    {
      "Name": {
        "Namespace": "controller_config",
        "Key": "controller_url"
      },
      "Type": {
        "Kind": "string"
      },
      "Expression": "http://localhost:8080"
    },
    {
      "Name": {
        "Namespace": "controller_config",
        "Key": "ledger_db_path"
      },
      "Type": {
        "Kind": "path"
      },
      "Expression": ".run/controller/ledger.sqlite"
    }
  ],
  "execution_environment": {
    "name": "dockerized-slurm",
    "transports": [
      {
        "name": "control",
        "type": "docker",
        "settings": {
          "container": "slurmctld"
        }
      }
    ],
    "dialect": {
      "type": "bash"
    },
    "scheduler": {
      "type": "slurm"
    },
    "runtime": {
      "type": "shared_filesystem_worker",
      "settings": {
        "root": "/data/goetl"
      }
    }
  }
}
