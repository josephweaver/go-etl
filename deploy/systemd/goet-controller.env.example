# Copy to /etc/goet/goet-controller.env and adjust for the target server.
# The file must be owned by root or the GOET service account and should not be
# world-readable when it contains private paths.

GOET_CONTROLLER_CONFIG=/etc/goet/controller.json

# Used only by the systemd ExecStop example. The controller itself should load
# credential files through controller_config.authentication in controller.json.
GOET_CONTROLLER_ADMIN_TOKEN_FILE=/etc/goet/secrets/controller-admin-token
