{
  "workflow": {
    "ID": "summary-demo",
    "Variables": [
      {
        "name": {
          "namespace": "workflow",
          "key": "summary_items"
        },
        "type": "list",
        "expression": [
          {
            "type": "object",
            "expression": {
              "id": {"type": "string", "expression": "fixture"},
              "input_path": {"type": "path", "expression": "demo-summary-input.txt"}
            }
          },
          {
            "type": "object",
            "expression": {
              "id": {"type": "string", "expression": "fixture-2"},
              "input_path": {"type": "path", "expression": "demo-summary-input-2.txt"}
            }
          }
        ]
      }
    ],
    "Steps": [
      {
        "ID": "summarize-input",
        "FanOut": {
          "WorkItem": {
            "FanOutExpression": "${summary_items[*]}",
            "IDTokenAccessor": ".id",
            "OutputAccessor": ".id",
            "Type": "summarize_input_file",
            "OutputPrefix": "summary-demo",
            "OutputExtension": ".txt",
            "Parameters": {
              "input_path": {
                "type": "path",
                "value": "unset"
              }
            },
            "ParameterAccessors": {
              "input_path": ".input_path"
            }
          }
        }
      }
    ]
  },
  "variables": [
    {
      "name": {
        "namespace": "worker_config",
        "key": "worker_target_environment"
      },
      "type": "string",
      "expression": "local"
    },
    {
      "name": {
        "namespace": "worker_config",
        "key": "worker_start_executable"
      },
      "type": "string",
      "expression": "go"
    },
    {
      "name": {
        "namespace": "worker_config",
        "key": "worker_start_args"
      },
      "type": "list",
      "expression": [
        {"type": "string", "expression": "run"},
        {"type": "string", "expression": "./cmd/worker"},
        {"type": "string", "expression": "./cmd/worker/demo-config.json"}
      ]
    },
    {
      "name": {
        "namespace": "worker_config",
        "key": "worker_min_count"
      },
      "type": "int",
      "expression": 1
    },
    {
      "name": {
        "namespace": "worker_config",
        "key": "worker_max_count"
      },
      "type": "int",
      "expression": 1
    },
    {
      "name": {
        "namespace": "worker_config",
        "key": "worker_count_per_start"
      },
      "type": "int",
      "expression": 1
    },
    {
      "name": {
        "namespace": "worker_config",
        "key": "worker_min_elapsed_time_between_starts"
      },
      "type": "string",
      "expression": "0s"
    }
  ]
}
