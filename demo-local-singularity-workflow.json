{
  "workflow": {
    "ID": "local-singularity-demo",
    "Variables": [
      {
        "Name": {
          "Namespace": "workflow",
          "Key": "years"
        },
        "Type": {
          "Kind": "list",
          "Element": {
            "Kind": "int"
          }
        },
        "Expression": "[2024]"
      }
    ],
    "Steps": [
      {
        "ID": "write-demo",
        "FanOut": {
          "WorkItem": {
            "FanOutExpression": "${years[*]}",
            "Type": "write_demo_output",
            "OutputPrefix": "local-singularity-demo",
            "OutputExtension": ".txt"
          }
        }
      }
    ]
  },
  "variables": [
    {
      "Name": {
        "Namespace": "worker_config",
        "Key": "scheduler"
      },
      "Type": {
        "Kind": "object"
      },
      "Expression": "{\"type\":\"direct_process\",\"settings\":{\"script_path\":\"/tmp/goetl-local-singularity/scripts/worker.slurm\",\"job_name\":\"goetl-worker\"}}"
    },
    {
      "Name": {
        "Namespace": "worker_config",
        "Key": "runtime"
      },
      "Type": {
        "Kind": "object"
      },
      "Expression": "{\"type\":\"singularity_worker\",\"settings\":{\"executable\":\"/tmp/goetl-local-singularity/artifacts/goetl-worker\",\"config_path\":\"/tmp/goetl-local-singularity/config/worker.json\",\"log_dir\":\"/tmp/goetl-local-singularity/logs\"}}"
    },
    {
      "Name": {
        "Namespace": "worker_config",
        "Key": "worker_min_count"
      },
      "Type": {
        "Kind": "int"
      },
      "Expression": "1"
    },
    {
      "Name": {
        "Namespace": "worker_config",
        "Key": "worker_max_count"
      },
      "Type": {
        "Kind": "int"
      },
      "Expression": "1"
    },
    {
      "Name": {
        "Namespace": "worker_config",
        "Key": "worker_count_per_start"
      },
      "Type": {
        "Kind": "int"
      },
      "Expression": "1"
    },
    {
      "Name": {
        "Namespace": "worker_config",
        "Key": "worker_min_elapsed_time_between_starts"
      },
      "Type": {
        "Kind": "string"
      },
      "Expression": "0s"
    }
  ]
}
